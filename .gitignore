# Anchor these to the repo root only — without the leading slash they
# would also block legitimate package.json files in subdirectories
# (e.g. mobile/package.json, which is the Capacitor build config). The
# root-level ones exist only because an accidental `npm install wrangler@4`
# earlier put a dev dep at the repo root we don't want to track.
/node_modules/
/package.json
/package-lock.json
.claude/

# Capacitor / native build chain
mobile/node_modules/
mobile/www/
mobile/android/.gradle/
mobile/android/local.properties
mobile/android/build/
mobile/android/app/build/
mobile/android/app/release/
mobile/android/.idea/
mobile/android/captures/
mobile/ios/App/Pods/
mobile/ios/App/build/
mobile/ios/DerivedData/

# Local dev / tunnel artifacts
.tunnel/

# Built artifacts
*.apk
*.aab

# Signing materials — NEVER commit these. Lose the keystore and you lose
# the ability to push updates to the Play Store listing under the same
# package id. Back the .jks file up out-of-band (password manager, etc.).
*.jks
*.keystore
mobile/android/keystore.properties

# OS / editor
.DS_Store
Thumbs.db
*.log
